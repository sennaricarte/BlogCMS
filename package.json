{
  "name": "blogcms",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "node scripts/clean-vite-cache.mjs && astro dev",
    "sync:template": "tsx scripts/sync-template-astro.ts",
    "prebuild": "npm run sync:template",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "node --max-old-space-size=8192 ./node_modules/astro/bin/astro.mjs check --minimumSeverity warning",
    "check:with-hints": "node --max-old-space-size=8192 ./node_modules/astro/bin/astro.mjs check",
    "check:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "test:deploy": "tsx scripts/test-deploy.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.4",
    "@astrojs/vercel": "^10.0.5",
    "@octokit/rest": "^22.0.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/extension-youtube": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "astro": "^6.1.9",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.7.2",
    "gray-matter": "^4.0.3",
    "github-slugger": "^2.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.11.0",
    "marked": "^18.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2"
  }
}
