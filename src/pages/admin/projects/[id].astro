---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import Icon from "../../../components/admin/Icon.astro";
import { readProjectsData } from "../../../lib/project-manager";
import { ADMIN_CMS_TARGET_KEY, getCmsTargetFromProject } from "../../../lib/admin-cms-target";
import type { ClientProject } from "../../../lib/projects-data";
import {
  projectPublicSiteUrl,
  projectVercelDeploymentsUrl,
  projectVercelSpeedInsightsUrl,
} from "../../../lib/vercel-project-admin-links";

const rawId = Astro.params.id;
const { projects: projectsList } = await readProjectsData();
const projects: ClientProject[] = Array.isArray(projectsList) ? projectsList : [];
const project = rawId ? projects.find((p) => p.id === rawId) : undefined;

if (!project) {
  return Astro.redirect("/admin/dashboard/", 302);
}

const pageTitle = `${project.name} · Site`;
const pageDescription = `Repositório ${project.githubRepoFullName} · Vercel ${project.vercelProjectName}`;
const canonicalPath = `/admin/projects/${project.id}/`;
const cmsTarget = getCmsTargetFromProject(project);
const cmsTargetJson = cmsTarget ? JSON.stringify(cmsTarget) : "";
const publicUrl = projectPublicSiteUrl(project);
const logsUrl = projectVercelDeploymentsUrl(project);
const analyticsUrl = projectVercelSpeedInsightsUrl(project);
/** Indicador estático até haver cálculo real (Lighthouse, Content API, etc.). */
const SEO_HEALTH_SCORE = 78;
const seoBarClass =
  SEO_HEALTH_SCORE >= 80
    ? "bg-emerald-500"
    : SEO_HEALTH_SCORE >= 60
      ? "bg-amber-500"
      : "bg-red-500";
const seoTextClass =
  SEO_HEALTH_SCORE >= 80
    ? "text-emerald-800"
    : SEO_HEALTH_SCORE >= 60
      ? "text-amber-800"
      : "text-red-800";
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  section="project"
  canonicalPath={canonicalPath}
>
  {
    cmsTarget && (
      <script is:inline define:vars={{ k: ADMIN_CMS_TARGET_KEY, t: cmsTargetJson }}>
        try {
          localStorage.setItem(k, t);
        } catch (e) {}
      </script>
    )
  }

  <div class="mb-6">
    <nav class="text-sm" aria-label="Caminho no painel">
      <ol class="flex flex-wrap items-center gap-1.5 text-zinc-500">
        <li>
          <a
            class="font-medium text-zinc-700 underline-offset-2 hover:underline"
            href="/admin/dashboard/"
          >Painel</a>
        </li>
        <li class="text-zinc-300" aria-hidden="true">/</li>
        <li class="min-w-0 font-medium text-zinc-900" aria-current="page">
          {project.name}
        </li>
      </ol>
    </nav>
  </div>

  <div
    class="mb-6 rounded-2xl border border-slate-200/80 bg-gradient-to-br from-slate-50/90 via-white to-slate-50/50 px-5 py-5 shadow-sm sm:px-6"
  >
    <h2 class="text-xl font-bold tracking-tight text-slate-900">Visão geral</h2>
    <p class="mt-1.5 text-sm text-slate-600">
      Este ecrã define o alvo do CMS: GitHub e Vercel passam a ser os destinos ao editares conteúdo noutros separadores.
    </p>
    <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-2">
      <div>
        <dt class="text-xs font-medium text-slate-500">Repositório (GitHub)</dt>
        <dd class="mt-0.5 break-all font-mono text-slate-900">{project.githubRepoFullName}</dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-slate-500">Projeto (Vercel)</dt>
        <dd class="mt-0.5 font-mono text-slate-900">{project.vercelProjectName}</dd>
      </div>
      <div class="sm:col-span-2">
        <dt class="text-xs font-medium text-slate-500">Produção</dt>
        <dd class="mt-0.5 break-all">
          <a
            class="font-medium text-slate-800 underline-offset-2 hover:underline"
            href={publicUrl}
            target="_blank"
            rel="noopener noreferrer"
          >{publicUrl}</a>
        </dd>
      </div>
    </dl>
  </div>

  <section
    class="mb-6 rounded-2xl border border-slate-200/80 bg-white px-5 py-5 shadow-sm sm:px-6"
    aria-labelledby="heading-seo-health"
  >
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2
          id="heading-seo-health"
          class="text-sm font-semibold uppercase tracking-[0.1em] text-slate-500"
        >SEO Health Score</h2>
        <p class="mt-1 text-sm text-slate-600">Resumo do estado de SEO técnico e de conteúdo do site (prévia).</p>
      </div>
      <div class="sm:min-w-[12rem] sm:text-right">
        <p
          class={["text-4xl font-bold tabular-nums tracking-tight", seoTextClass].join(" ")}
          aria-label={`${SEO_HEALTH_SCORE} de 100 pontos`}
        >
          {SEO_HEALTH_SCORE}
          <span class="text-lg font-semibold text-slate-400">/100</span>
        </p>
      </div>
    </div>
    <div
      class="mt-4 h-2.5 w-full overflow-hidden rounded-full bg-slate-100"
      role="meter"
      aria-label="Nível de saúde SEO"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow={SEO_HEALTH_SCORE}
    >
      <div
        class={["h-full rounded-full transition-[width]", seoBarClass].join(" ")}
        style={`width: ${SEO_HEALTH_SCORE}%`}
      />
    </div>
    <p class="mt-3 text-xs text-slate-500" role="note">
      Valor estático de exemplo; em seguida poderás ligar auditorias, Core Web Vitals e verificações de metadados.
    </p>
  </section>

  {
    !cmsTarget && (
      <p
        class="mb-6 rounded-lg border border-amber-200/90 bg-amber-50/90 px-3 py-2 text-sm text-amber-950"
        role="status"
      >
        Define <code class="rounded bg-amber-100/80 px-1 font-mono text-xs">githubRepoFullName</code> com um repositório
        real em <code class="font-mono text-xs">src/data/projects.json</code> para o CMS e o &quot;Publicar&quot; reconhecerem
        o alvo.
      </p>
    )
  }

  <section class="mb-2" aria-labelledby="heading-atalhos-cms">
    <h2 id="heading-atalhos-cms" class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
      Atalhos do CMS
    </h2>
    <ul class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      <li
        class="group rounded-xl border border-slate-200/80 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <a
          class="block focus:outline-none focus:ring-2 focus:ring-slate-400/30 rounded-md"
          href="/admin/posts/"
          aria-label="Posts: artigos e listagem"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-200/80 bg-slate-50 text-slate-600 group-hover:border-slate-300">
            <Icon kind="file-text" />
          </span>
          <span class="mt-2 block font-semibold text-slate-900">Posts</span>
          <span class="mt-0.5 block text-xs text-slate-500">Artigos e editor</span>
        </a>
      </li>
      <li
        class="group rounded-xl border border-slate-200/80 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <a
          class="block focus:outline-none focus:ring-2 focus:ring-slate-400/30 rounded-md"
          href="/admin/pages/"
          aria-label="Páginas: markdown"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-200/80 bg-slate-50 text-slate-600 group-hover:border-slate-300">
            <Icon kind="document" />
          </span>
          <span class="mt-2 block font-semibold text-slate-900">Páginas</span>
          <span class="mt-0.5 block text-xs text-slate-500">Markdown / ficheiros no repositório</span>
        </a>
      </li>
      <li
        class="group rounded-xl border border-slate-200/80 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <a
          class="block focus:outline-none focus:ring-2 focus:ring-slate-400/30 rounded-md"
          href="/admin/taxonomies/"
          aria-label="Categorias e taxonomias"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-200/80 bg-slate-50 text-slate-600 group-hover:border-slate-300">
            <Icon kind="folder" />
          </span>
          <span class="mt-2 block font-semibold text-slate-900">Categorias</span>
          <span class="mt-0.5 block text-xs text-slate-500">Taxonomias</span>
        </a>
      </li>
      <li
        class="group rounded-xl border border-slate-200/80 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <a
          class="block focus:outline-none focus:ring-2 focus:ring-slate-400/30 rounded-md"
          href="/admin/settings/"
          aria-label="Definições: tokens e alvo do CMS"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-200/80 bg-slate-50 text-slate-600 group-hover:border-slate-300">
            <Icon kind="adjustments" />
          </span>
          <span class="mt-2 block font-semibold text-slate-900">Definições</span>
          <span class="mt-0.5 block text-xs text-slate-500">Tokens e alvo do CMS</span>
        </a>
      </li>
      <li
        class="group rounded-xl border border-slate-200/80 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <a
          class="block focus:outline-none focus:ring-2 focus:ring-slate-400/30 rounded-md"
          href={analyticsUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Analytics: Vercel Speed Insights (abre em novo separador)"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-emerald-200/80 bg-emerald-50/80 text-emerald-800 group-hover:border-emerald-300">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 19V11M10 19v-6M16 19V5" />
            </svg>
          </span>
          <span class="mt-2 block font-semibold text-slate-900">Analytics</span>
          <span class="mt-0.5 block text-xs text-slate-500">Speed Insights (Vercel)</span>
        </a>
      </li>
    </ul>
  </section>

  <p class="mt-8 text-sm text-slate-500">
    <a
      class="font-medium text-slate-700 underline-offset-2 hover:underline"
      href={logsUrl}
      target="_blank"
      rel="noopener noreferrer"
    >Ver logs de deploy</a> na Vercel (repositório e projeto já associados a este registo).
  </p>
</AdminLayout>
