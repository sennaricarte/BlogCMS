---
export const prerender = false;

import { readFileSync } from "node:fs";
import path from "node:path";
import matter from "gray-matter";
import { getEntry } from "astro:content";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { EditPostBodyField } from "../../../../components/admin/EditPostBodyField";
import taxonomies from "../../../../data/taxonomies.json";
import clientConfig from "../../../../data/client-config.json";

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/admin/posts/", 302);
}

const entry = await getEntry("blog", slug);
if (!entry) {
  return Astro.redirect("/admin/posts/", 302);
}

const pageTitle = "Editar artigo";
const pageDescription =
  "Conteúdo em Markdown, SEO e taxonomias. Salvar envia o commit ao repositório (GitHub) via o publicador do CMS.";

let rawHero = "";
try {
  const abs = path.join(process.cwd(), "src/content/blog", `${slug}.md`);
  const raw = readFileSync(abs, "utf-8");
  const { data: fm } = matter(raw);
  if (typeof fm.heroImage === "string" && fm.heroImage.trim()) {
    rawHero = fm.heroImage.trim();
  }
} catch {
  // Sem arquivo local: usa padrão
}
if (!rawHero) {
  rawHero = "../../assets/blog/hero-primeiro.svg";
}

const d = entry.data;
const publicSiteBase = (clientConfig as { siteUrl?: string }).siteUrl?.replace(/\/$/, "") ?? "";
const initialPayload = {
  slug,
  title: d.title,
  seoTitle: d.seoTitle ?? "",
  seoFocusKeyword: d.seoFocusKeyword ?? "",
  description: d.description,
  body: entry.body,
  pubDate: d.pubDate.toISOString().slice(0, 10),
  updatedDate: d.updatedDate ? d.updatedDate.toISOString().slice(0, 10) : "",
  author: d.author,
  heroImage: rawHero,
  tags: d.tags ?? [],
  category: d.category ? String(d.category).trim().toLowerCase() : "",
  draft: d.draft,
  scheduled: Boolean(d.scheduled),
};
const initialJson = JSON.stringify(initialPayload).replace(/</g, "\\u003c");

const taxonomiesJson = JSON.stringify(taxonomies);
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  section="posts"
  canonicalPath={`/admin/posts/edit/${slug}/`}
>
  <p class="mb-4 text-sm text-slate-600">
    <a href="/admin/posts/" class="text-[var(--client-color-primary)] hover:underline">← Artigos</a>
  </p>

  <form id="f-post" class="space-y-6" novalidate data-cms="post-form">
    <div
      id="post-form-root"
      class="space-y-6"
      data-mode="edit"
      data-initial-slug={slug}
      data-taxonomies={taxonomiesJson}
      data-public-site={publicSiteBase}
    >
      <script type="application/json" id="server-initial" set:html={initialJson} is:inline
      ></script>
      <div
        class="hidden rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900"
        id="f-msg"
        role="status"
        aria-live="polite"
      >
      </div>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(17.5rem,22rem)] lg:items-start">
        <div class="min-w-0 space-y-4">
          <div>
            <label for="f-title" class="block text-sm font-medium text-slate-800">Título</label>
            <input
              id="f-title"
              name="title"
              type="text"
              required
              class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900/10"
              aria-required="true"
            />
          </div>
          <div>
            <p class="text-sm font-medium text-slate-800">Conteúdo</p>
            <p class="mt-0.5 text-xs text-slate-500">
              Editor rico (TipTap). O arquivo é salvo em Markdown; a pré-visualização de Markdown vem abaixo.
            </p>
            <input type="hidden" id="f-body" name="body" value="" />
            <div class="mt-2 w-full min-w-0">
              <EditPostBodyField client:load initialMarkdown={entry.body}>
                <p slot="fallback" class="min-h-40 rounded-lg border border-slate-200 bg-slate-50/80 p-4 text-sm text-slate-600">
                  Carregando o editor…
                </p>
              </EditPostBodyField>
            </div>
          </div>
          <div
            class="overflow-hidden rounded-xl border border-slate-200/90 bg-white shadow-sm"
          >
            <p class="border-b border-slate-200 bg-slate-50/80 px-3 py-2 text-xs font-medium uppercase tracking-wide text-slate-500">
              Pré‑visualização
            </p>
            <div
              id="f-md-preview"
              class="prose prose-slate min-h-[12rem] max-w-none p-4 text-sm"
            >
            </div>
          </div>
        </div>

        <aside
          class="space-y-5 rounded-xl border border-slate-200/90 bg-white p-4 shadow-sm lg:sticky lg:top-4"
          aria-label="Análise de SEO, URL e publicação"
        >
          <section class="space-y-4" aria-labelledby="f-seo-aside-h">
            <h2
              id="f-seo-aside-h"
              class="text-xs font-semibold uppercase tracking-wider text-slate-500"
            >
              Análise de SEO
            </h2>

            <div>
              <div class="flex items-end justify-between gap-2">
                <label for="f-seo-title" class="text-sm font-medium text-slate-800"> SEO Title </label>
                <span
                  class="text-xs font-medium tabular-nums text-amber-700"
                  id="f-seo-title-count"
                  aria-live="polite"
                >
                  0/60
                </span>
              </div>
              <input
                type="text"
                id="f-seo-title"
                name="seoTitle"
                maxlength="100"
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900"
                placeholder="Sugestão: 50–60 carateres"
                aria-describedby="f-seo-title-hint"
              />
              <p class="mt-1 text-xs text-slate-500" id="f-seo-title-hint">
                Título para resultados de busca (opcional; o artigo mostra o título principal abaixo).
              </p>
            </div>

            <div>
              <div class="flex items-end justify-between gap-2">
                <label for="f-desc" class="text-sm font-medium text-slate-800">Meta description</label>
                <span
                  class="text-xs font-medium tabular-nums text-amber-700"
                  id="f-desc-count"
                  aria-live="polite"
                >
                  0/160
                </span>
              </div>
              <textarea
                id="f-desc"
                name="description"
                required
                maxlength="160"
                rows="3"
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900"
                aria-describedby="f-desc-hint"
              ></textarea>
              <p class="mt-1 text-xs text-slate-500" id="f-desc-hint">
                Resumo (ideal cerca de 120–160 carateres).
              </p>
            </div>

            <div>
              <label for="f-seo-keyword" class="text-sm font-medium text-slate-800"> Palavra-chave foco </label>
              <input
                type="text"
                id="f-seo-keyword"
                name="seoFocusKeyword"
                maxlength="200"
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900"
                placeholder="Uma frase para verificar título, texto e links"
                aria-describedby="f-seo-checklist"
                autocomplete="off"
              />
            </div>

            <ul
              id="f-seo-checklist"
              class="list-none space-y-2 text-sm"
              role="list"
              aria-label="Controlo de conteúdo com base na palavra-chave e no corpo"
            >
              <li class="flex gap-2">
                <span class="w-4 shrink-0" id="f-seo-c-h1">—</span>
                <span>A palavra-chave aparece no título (H1 do artigo)?</span>
              </li>
              <li class="flex gap-2">
                <span class="w-4 shrink-0" id="f-seo-c-p1">—</span>
                <span>A palavra-chave aparece no primeiro parágrafo?</span>
              </li>
              <li class="flex gap-2">
                <span class="w-4 shrink-0" id="f-seo-c-lint">—</span>
                <span>Existem <span class="font-medium">links internos</span>?</span>
              </li>
              <li class="flex gap-2">
                <span class="w-4 shrink-0" id="f-seo-c-lext">—</span>
                <span>Existem <span class="font-medium">links externos</span>?</span>
              </li>
              <li class="flex gap-2">
                <span class="w-4 shrink-0" id="f-seo-c-alt">—</span>
                <span>As imagens no texto têm <span class="font-medium">alt</span>?</span>
              </li>
            </ul>

            <div class="rounded-lg border border-slate-200 bg-slate-50/80 px-3 py-2">
              <p class="text-xs font-medium text-slate-600">Prévia da URL do post</p>
              <p
                class="mt-1 break-all font-mono text-xs text-slate-800"
                id="f-seo-slug-preview"
                aria-live="polite"
              >
              </p>
            </div>
          </section>

          <div class="border-t border-slate-100 pt-4">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Ficheiro e slug</h2>
            <div class="mt-3">
            <div class="flex items-center justify-between gap-2">
              <label for="f-slug" class="text-sm font-medium text-slate-800"
                >Slug do arquivo</label
              >
              <label class="inline-flex items-center gap-1.5 text-xs text-slate-500">
                <input type="checkbox" id="f-auto-slug" class="rounded border-slate-300" />
                Auto
              </label>
            </div>
            <input
              id="f-slug"
              name="slug"
              type="text"
              required
              pattern="[a-z0-9][a-z0-9-]*"
              class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 font-mono text-sm text-slate-900 shadow-sm"
              aria-describedby="f-slug-hint"
            />
            <p class="mt-1 text-xs text-slate-500" id="f-slug-hint">
              Arquivo: <code class="text-xs text-slate-600" id="f-slug-file">{slug}.md</code>
            </p>
            </div>
          </div>

          <div class="border-t border-slate-100 pt-4">
            <h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500"
              >Categorias e etiquetas</h2
            >
            <div class="mb-4">
              <label for="f-cat" class="block text-sm font-medium text-slate-800">Categoria</label>
              <select
                id="f-cat"
                name="category"
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"
              >
                <option value="">— nenhuma —</option>
              </select>
              <button
                type="button"
                id="btn-new-cat"
                class="mt-2 w-full text-left text-xs font-medium text-[var(--client-color-primary)] underline-offset-2 hover:underline"
              >
                + Nova categoria (GitHub)
              </button>
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800">Etiquetas</span>
              <p class="text-xs text-slate-500">Sugestões: <span id="f-sugg-hint"></span></p>
              <div
                id="f-tag-box"
                class="mt-2 flex flex-wrap gap-2"
                role="group"
                aria-label="Selecionar etiquetas"
              >
              </div>
              <button
                type="button"
                id="btn-new-tag"
                class="mb-1 mt-1 w-full text-left text-xs font-medium text-[var(--client-color-primary)] underline-offset-2 hover:underline"
              >
                + Nova etiqueta (GitHub)
              </button>
              <div class="mt-2">
                <label for="f-tags" class="sr-only">Outras etiquetas (vírgula)</label>
                <input
                  id="f-tags"
                  name="tagsRaw"
                  type="text"
                  class="w-full rounded-lg border border-slate-200 px-3 py-1.5 text-sm"
                  placeholder="Outras, separadas por vírgula"
                />
              </div>
              <input type="hidden" name="tagsJson" id="f-tags-hidden" value="[]" />
            </div>
          </div>

          <div class="space-y-3 border-t border-slate-100 pt-4">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500"
              >Publicação</h2
            >
            <div>
              <label for="f-pub" class="block text-sm font-medium text-slate-800"
                >Data de publicação</label
              >
              <input
                id="f-pub"
                name="pubDate"
                type="date"
                required
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"
                aria-describedby="f-schedule-hint f-pub-d"
              />
              <p class="mt-0.5 text-xs text-slate-500" id="f-pub-d">
                Artigos com <strong>data futura</strong> ficam em rascunho até essa data (publicação agendada).
              </p>
              <p class="mt-1.5 min-h-[1.25rem] text-xs" id="f-schedule-hint" role="status" aria-live="polite"></p>
            </div>
            <div>
              <label for="f-upd" class="block text-sm font-medium text-slate-800"
                >Data de atualização (opcional)</label
              >
              <input
                id="f-upd"
                name="updatedDate"
                type="date"
                class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"
              />
            </div>
            <div>
              <label for="f-auth" class="block text-sm font-medium text-slate-800">Autor</label>
              <input
                id="f-auth"
                name="author"
                type="text"
                class="mt-1.5 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm"
              />
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800">Imagem de destaque</span>
              <p class="mt-0.5 text-xs text-slate-500">
                O arquivo vai para
                <code class="mx-0.5 rounded bg-slate-100 px-0.5 font-mono text-[0.7rem]">src/assets/blog/</code> no
                GitHub; o
                caminho no front matter é definido automaticamente ao enviar.
              </p>
              <div class="mt-1.5 flex flex-wrap items-center gap-2">
                <input
                  id="f-hero-file"
                  type="file"
                  accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml"
                  class="sr-only"
                  aria-describedby="f-hero-file-name"
                />
                <label
                  for="f-hero-file"
                  class="inline-flex cursor-pointer items-center rounded-md border border-slate-200 bg-slate-100 px-2.5 py-1.5 text-sm font-medium text-slate-800 shadow-sm transition hover:bg-slate-200"
                >
                  Escolher arquivo
                </label>
                <span
                  id="f-hero-file-name"
                  class="min-w-0 max-w-[14rem] truncate text-xs text-slate-500"
                  aria-live="polite"
                >Nenhum arquivo selecionado</span>
                <span id="f-hero-upload-status" class="text-xs text-slate-500" aria-live="polite"></span>
              </div>
              <input id="f-hero" name="heroImage" type="hidden" value="" />
            </div>
            <div class="flex items-center gap-2">
              <input type="checkbox" id="f-draft" name="draft" class="rounded border-slate-300" />
              <label for="f-draft" class="text-sm text-slate-800"
                >Rascunho (não exibir no site)</label
              >
            </div>
          </div>
        </aside>
      </div>

      <div class="flex flex-wrap items-center gap-3 border-t border-slate-200 pt-4">
        <button
          type="button"
          id="f-save"
          class="inline-flex min-h-[2.5rem] items-center justify-center rounded-lg bg-slate-900 px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900/30 disabled:cursor-not-allowed disabled:opacity-50"
        >
          Salvar alterações
        </button>
        <span class="text-sm text-slate-500" id="f-saving" aria-live="polite"></span>
        <button
          type="button"
          id="f-delete"
          class="ml-auto inline-flex items-center justify-center rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-800 transition hover:bg-red-100"
        >
          Excluir
        </button>
      </div>
    </div>
  </form>
</AdminLayout>

<script>
  import "../../../../scripts/post-editor.ts";
</script>
