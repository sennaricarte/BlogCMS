---
import HeroCover from "../components/blog/HeroCover.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { blogPostHref, getPublicBlogPosts } from "../lib/blog";
import { getCategoryDisplayName, getTagDisplayName, tagToSlug } from "../lib/taxonomies";

const includeDrafts = false;
const sorted = await getPublicBlogPosts(includeDrafts);
const latest = sorted.slice(0, 5);
---

<BaseLayout title="Início" description="Página inicial com os últimos artigos do blog.">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Bem-vindo</h1>
    <p class="mt-2 text-lg text-slate-600">
      Conteúdo com metadados e cores a partir de
      <code class="rounded bg-slate-100 px-1 text-sm">site-config.json</code>
      <span class="text-slate-500"> e posts em</span> <code class="rounded bg-slate-100 px-1 text-sm">src/content/blog</code>.
    </p>

    <section class="mt-12" aria-labelledby="sec-recentes">
      <h2 id="sec-recentes" class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Últimos artigos</h2>
      {latest.length === 0 ? (
        <p class="mt-4 text-slate-600">Ainda sem publicações.</p>
      ) : (
        <ol class="mt-6 space-y-8" aria-label="Cinco publicações mais recentes">
          {latest.map((post, index) => (
            <li>
              <article class="group flex flex-col gap-4 border-b border-slate-200 pb-8 last:border-0 sm:flex-row sm:items-stretch">
                <a href={blogPostHref(post.id)} class="block shrink-0 overflow-hidden rounded-lg ring-1 ring-slate-200" aria-hidden="true" tabindex={-1}>
                  <HeroCover
                    src={post.data.heroImage}
                    alt=""
                    width={480}
                    height={252}
                    class="h-48 w-full object-cover transition group-hover:opacity-95 sm:h-full sm:min-w-[12rem] sm:max-w-[12rem]"
                    sizes="(min-width: 40rem) 12rem, 100vw"
                    priority={index === 0}
                  />
                </a>
                <div class="min-w-0 flex-1">
                  <h3 class="text-xl font-semibold text-slate-900">
                    <a
                      href={blogPostHref(post.id)}
                      class="text-[var(--client-color-primary)] decoration-transparent underline-offset-2 hover:underline"
                    >
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="mt-1 text-sm text-slate-500" aria-label="Resumo e data do artigo">
                    <time datetime={post.data.pubDate.toISOString()} class="whitespace-nowrap">
                      {post.data.pubDate.toLocaleDateString("pt-PT", { year: "numeric", month: "short", day: "numeric" })}
                    </time>
                    <span class="px-1">·</span>
                    <span class="line-clamp-2 sm:line-clamp-none">{post.data.description}</span>
                  </p>
                  {(post.data.category || post.data.tags.length > 0) && (
                    <div class="mt-3 flex flex-col gap-1.5 text-sm">
                      {post.data.category && (
                        <p class="text-slate-600">
                          <span class="font-medium text-slate-700">Categoria: </span>
                          <a
                            href={`/category/${String(post.data.category).trim().toLowerCase()}/`}
                            class="text-[var(--client-color-primary)] underline-offset-2 hover:underline"
                          >
                            {getCategoryDisplayName(post.data.category)}
                          </a>
                        </p>
                      )}
                      {post.data.tags.length > 0 && (
                        <div class="text-slate-600">
                          <span class="font-medium text-slate-700">Etiquetas: </span>
                          <ul
                            class="ml-0 mt-1 flex list-none flex-wrap gap-2 pl-0"
                            aria-label="Etiquetas com ligação para arquivo"
                          >
                            {post.data.tags.map((t) => (
                              <li>
                                <a
                                  href={`/tag/${tagToSlug(t)}/`}
                                  class="text-[var(--client-color-primary)] underline-offset-2 hover:underline"
                                >
                                  {getTagDisplayName(t)}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </article>
            </li>
          ))}
        </ol>
      )}
      {latest.length > 0 && (
        <p class="mt-8 text-center sm:text-left">
          <a
            href="/blog/"
            class="text-sm font-medium text-[var(--client-color-primary)] underline-offset-2 hover:underline"
          >
            Ver blog completo
          </a>
        </p>
      )}
    </section>
  </div>
</BaseLayout>
