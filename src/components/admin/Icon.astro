---
/** Contornos estilo Heroicons (24×24), sem dependências npm. */
type IconKind =
  | "layout-dashboard"
  | "file-text"
  | "document"
  | "image"
  | "folder"
  | "tag"
  | "adjustments"
  | "alert-triangle"
  | "layout-rows"
  | "palette"
  | "arrow-down-tray";

const { kind, class: className = "" } = Astro.props as {
  kind: IconKind;
  class?: string;
};

const base = "inline-block h-4 w-4 shrink-0 " + (className || "").trim();
---

{
  kind === "layout-dashboard" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75a2.25 2.25 0 0 1 2.25-2.25h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25v-2.25ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"
      />
    </svg>
  )
}
{
  kind === "file-text" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 14.25v-2.625a.375.375 0 0 0-.375-.375H14.25a1.125 1.125 0 0 1-1.125-1.125V4.5H6a.75.75 0 0 0-.75.75v15a.75.75 0 0 0 .75.75h12a.75.75 0 0 0 .75-.75V14.25Zm-1.5-4.5h-4.5a.375.375 0 0 1-.375-.375V4.5l5.25 5.25Z"
      />
    </svg>
  )
}
{
  kind === "document" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 14.25v-2.625a.375.375 0 0 0-.375-.375H14.25a1.125 1.125 0 0 1-1.125-1.125V4.5H6a.75.75 0 0 0-.75.75v15a.75.75 0 0 0 .75.75h12a.75.75 0 0 0 .75-.75V14.25Z"
      />
    </svg>
  )
}
{
  kind === "image" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m2.25 15.75 5.4-5.4a.75.75 0 0 1 1.05 0l4.1 4.1a.75.75 0 0 0 1.05 0L21 6.9M4.5 19.5h15A2.25 2.25 0 0 0 21.75 17.25v-7.5A2.25 2.25 0 0 0 19.5 7.5h-1.26a.75.75 0 0 1-.53-.22L15.3 3.6a.75.75 0 0 0-.54-.24H6A2.25 2.25 0 0 0 3.75 5.6v11.65A2.25 2.25 0 0 0 6 19.5Z"
      />
    </svg>
  )
}
{
  kind === "folder" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h5.25a2.25 2.25 0 0 1 2.25 2.25v.75m-12 0V18A2.25 2.25 0 0 0 4.5 20.25h15A2.25 2.25 0 0 0 21.75 18v-4.875a2.25 2.25 0 0 0-2.25-2.25h-4.5a2.25 2.25 0 0 0-2.25 2.25v.75m-12 0h.008v.008H2.25v-.008Z"
      />
    </svg>
  )
}
{
  kind === "tag" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"
      />
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
    </svg>
  )
}
{
  kind === "adjustments" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M10.5 6h9.75M10.5 18h9.75M4.5 6h.007v.008H4.5V6Zm0 6h.007v.008H4.5v-.008Zm0 6h.007v.008H4.5v-.008Z"
      />
    </svg>
  )
}
{
  kind === "layout-rows" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3.75 5.25h16.5M3.75 9.75h16.5M3.75 15h10.5M3.75 19.5h16.5"
      />
    </svg>
  )
}
{
  kind === "palette" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M7.5 8.25a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3ZM12 8.25a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3ZM16.5 8.25a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3ZM7.5 15.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3ZM12 15.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3ZM16.5 15.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"
      />
    </svg>
  )
}
{
  kind === "arrow-down-tray" && (
    <svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
      />
    </svg>
  )
}
{
  kind === "alert-triangle" && (
    <svg
      class={base + " text-amber-500"}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.031-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"
      />
    </svg>
  )
}
