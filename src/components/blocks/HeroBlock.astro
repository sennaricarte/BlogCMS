---
import type { PageBlock } from "../../lib/page-blocks.zod";

type P = Extract<PageBlock, { type: "hero" }> & { class?: string };

const props = Astro.props as P;
const {
  id,
  layout: layoutRaw,
  tagline,
  title,
  description,
  subtitle,
  imageSrc,
  imageAlt,
  primaryButton,
  secondaryButton,
  class: className = "",
} = props;

const layout = layoutRaw ?? "classic";
const bodyText = (description || "").trim() || (subtitle || "").trim();
const hasPrimary = Boolean(primaryButton?.label?.trim() && primaryButton?.url?.trim());
const hasSecondary = Boolean(secondaryButton?.label?.trim() && secondaryButton?.url?.trim());
const imgAlt = (imageAlt || "").trim() || "Imagem de destaque";
const headingId = `hero-h-${id}`;

const btnPrimary =
  "inline-flex items-center justify-center rounded-lg bg-[var(--client-color-primary)] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:opacity-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--client-color-primary)]";
const btnSecondary =
  "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400";
---

{
  layout === "classic" && (
    <section
      class={`rounded-2xl border border-slate-200 border-t-4 border-t-[var(--primary-color)] bg-gradient-to-br from-slate-50 to-white px-6 py-10 shadow-sm ${className}`}
      aria-labelledby={headingId}
      aria-label="Cabeçalho de página"
    >
      <h2 id={headingId} class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
        {title}
      </h2>
      {bodyText && <p class="mt-2 max-w-2xl text-base leading-relaxed text-slate-600">{bodyText}</p>}
      {(hasPrimary || hasSecondary) && (
        <div class="mt-6 flex flex-wrap items-center gap-3">
          {hasPrimary && (
            <a href={primaryButton!.url} class={btnPrimary}>
              {primaryButton!.label}
            </a>
          )}
          {hasSecondary && (
            <a href={secondaryButton!.url} class={btnSecondary}>
              {secondaryButton!.label}
            </a>
          )}
        </div>
      )}
    </section>
  )
}

{
  layout === "centered" && (
    <section
      class={`rounded-2xl border border-slate-200 bg-white px-6 py-12 shadow-sm sm:px-10 sm:py-16 ${className}`}
      aria-labelledby={headingId}
    >
      <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
        {tagline?.trim() && (
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--client-color-primary)]">
            {tagline.trim()}
          </p>
        )}
        <h2 id={headingId} class={`mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl ${tagline?.trim() ? "" : "mt-0"}`}>
          {title}
        </h2>
        {bodyText && (
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg">{bodyText}</p>
        )}
        {(hasPrimary || hasSecondary) && (
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            {hasPrimary && (
              <a href={primaryButton!.url} class={btnPrimary}>
                {primaryButton!.label}
              </a>
            )}
            {hasSecondary && (
              <a href={secondaryButton!.url} class={btnSecondary}>
                {secondaryButton!.label}
              </a>
            )}
          </div>
        )}
      </div>
    </section>
  )
}

{
  (layout === "splitImageLeft" || layout === "splitImageRight") && (
    <section
      class={`rounded-2xl border border-slate-200 bg-white px-6 py-10 shadow-sm sm:px-8 sm:py-12 ${className}`}
      aria-labelledby={headingId}
    >
      <div class="grid items-center gap-8 md:grid-cols-2 md:gap-10 lg:gap-12">
        <div
          class:list={[
            layout === "splitImageLeft" ? "md:order-1" : "md:order-2",
          ]}
        >
          {imageSrc?.trim() ? (
            <img
              src={imageSrc.trim()}
              alt={imgAlt}
              class="h-auto w-full max-h-[min(22rem,50vh)] rounded-xl object-cover object-center shadow-md ring-1 ring-slate-900/5 md:max-h-[min(28rem,70vh)]"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div
              class="flex aspect-[4/3] w-full items-center justify-center rounded-xl bg-slate-200/90 ring-1 ring-slate-300/80"
              role="img"
              aria-label="Área para imagem (ainda sem URL definida)"
            >
              <svg class="h-16 w-24 text-slate-400" viewBox="0 0 96 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="4" y="10" width="88" height="44" rx="4" stroke="currentColor" stroke-width="2" />
                <path d="M12 46 L32 26 L48 38 L66 20 L84 36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="72" cy="18" r="5" stroke="currentColor" stroke-width="2" />
              </svg>
            </div>
          )}
        </div>
        <div
          class:list={[
            "min-w-0",
            layout === "splitImageLeft" ? "md:order-2" : "md:order-1",
          ]}
        >
          <h2 id={headingId} class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl lg:text-4xl">
            {title}
          </h2>
          {bodyText && <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">{bodyText}</p>}
          {(hasPrimary || hasSecondary) && (
            <div class="mt-8 flex flex-wrap items-center gap-3">
              {hasPrimary && (
                <a href={primaryButton!.url} class={btnPrimary}>
                  {primaryButton!.label}
                </a>
              )}
              {hasSecondary && (
                <a href={secondaryButton!.url} class={btnSecondary}>
                  {secondaryButton!.label}
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
