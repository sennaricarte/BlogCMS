---
import { MapLeaflet } from "../maps/MapLeaflet";
import type { PageBlock } from "../../lib/page-blocks.zod";

type P = Extract<PageBlock, { type: "mapLocation" }> & { class?: string };

const p = Astro.props as P;
const { title, address, directionsLabel, latitude, longitude, class: className = "" } = p;
const hasCoords =
  typeof latitude === "number" &&
  typeof longitude === "number" &&
  !Number.isNaN(latitude) &&
  !Number.isNaN(longitude);
const embedQuery = encodeURIComponent(address);
const iframeSrc = `https://www.google.com/maps?q=${embedQuery}&output=embed&z=16&hl=pt`;
const mapsSearchUrl = `https://www.google.com/maps/search/?api=1&query=${embedQuery}`;
const dirCoordsUrl = hasCoords
  ? `https://www.google.com/maps/dir/?api=1&destination=${latitude},${longitude}`
  : `https://www.google.com/maps/dir/?api=1&destination=${embedQuery}`;
---

<section
  class={`rounded-xl border border-slate-200 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 sm:p-6 ${className}`}
  aria-label="Mapa e localização"
>
  <div
    class="space-y-3 rounded-lg border border-slate-100 bg-slate-50/90 px-4 py-3.5 sm:px-5 sm:py-4"
  >
    {
      title && (
        <h2 class="text-lg font-semibold tracking-tight text-slate-900 sm:text-xl">{title}</h2>
      )
    }
    <p class="text-sm leading-relaxed text-slate-700">
      <span class="font-medium text-slate-800">Endereço</span>
      <span class="mt-0.5 block text-slate-600">{address}</span>
    </p>
    <a
      href={dirCoordsUrl}
      class="inline-flex min-h-11 w-full min-w-0 max-w-sm items-center justify-center gap-2 rounded-lg bg-[var(--primary-color)] px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:opacity-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--primary-color)] sm:w-auto"
      rel="nofollow noopener noreferrer"
      target="_blank"
      aria-label={`${directionsLabel} — abre o Google Maps num novo separador`}
    >
      <svg class="h-4 w-4 shrink-0 opacity-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
        />
      </svg>
      {directionsLabel}
    </a>
  </div>

  {
    hasCoords ? (
      <div class="mt-6 w-full min-w-0">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-slate-500">Mapa interactivo</p>
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-inner ring-1 ring-slate-900/5">
          <MapLeaflet client:load lat={latitude!} lng={longitude!} popupText={address} className="rounded-none border-0 shadow-none ring-0" />
        </div>
        <p class="mt-3 rounded-lg bg-slate-50 px-3 py-2 text-center text-xs leading-relaxed text-slate-500 ring-1 ring-slate-200/80">
          Mapa © OpenStreetMap (Leaflet). Usa o botão acima para abrir a rota no Google Maps.
        </p>
      </div>
    ) : (
      <div class="mt-6 w-full min-w-0">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-slate-500">Vista do mapa</p>
        <div class="relative aspect-[4/3] w-full min-h-[200px] overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-inner ring-1 ring-slate-900/5 sm:min-h-[280px]">
          <iframe
            title="Mapa do local"
            class="h-full w-full"
            src={iframeSrc}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
            aria-label={`Mapa centrado em ${address}`}
          />
        </div>
        <p class="mt-3 rounded-lg bg-slate-50 px-3 py-2 text-center text-xs leading-relaxed text-slate-500 ring-1 ring-slate-200/80">
          Com apenas o endereço, mostramos o mapa Google embutido. Defina coordenadas no editor para o mapa Leaflet interactivo.
        </p>
        <p class="mt-2 text-center">
          <a
            class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-[var(--primary-color)] shadow-sm transition hover:border-slate-300 hover:bg-slate-50"
            href={mapsSearchUrl}
            target="_blank"
            rel="nofollow noopener noreferrer"
          >
            Abrir no Google Maps
          </a>
        </p>
      </div>
    )
  }
</section>
