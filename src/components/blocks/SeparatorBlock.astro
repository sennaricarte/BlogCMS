---
import type { PageBlock } from "../../lib/page-blocks.zod";

type P = Extract<PageBlock, { type: "separator" }> & { class?: string };

const { style = "line", label, class: className = "" } = Astro.props as P;
const aria = label?.trim() || undefined;
---

{
  style === "space" ? (
    <div class={`h-10 w-full sm:h-14 ${className}`} aria-hidden="true" />
  ) : style === "dots" ? (
    <div
      class={`flex items-center justify-center gap-2 py-6 ${className}`}
      role={aria ? "separator" : "presentation"}
      aria-label={aria}
    >
      <span class="h-1.5 w-1.5 rounded-full bg-slate-300" aria-hidden="true" />
      <span class="h-1.5 w-1.5 rounded-full bg-slate-300" aria-hidden="true" />
      <span class="h-1.5 w-1.5 rounded-full bg-slate-300" aria-hidden="true" />
    </div>
  ) : (
    <hr
      class={`border-0 border-t border-slate-200 ${className}`}
      role={aria ? "separator" : undefined}
      aria-label={aria}
    />
  )
}
