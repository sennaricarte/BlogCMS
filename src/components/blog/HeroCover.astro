---
import { type ImageMetadata } from "astro:assets";
import { isHeroPublicAssetPath, isHeroRemoteUrl } from "../../lib/blog-hero-display";
import BlogImage from "./BlogImage.astro";

export interface Props {
  /** Coleção (`ImageMetadata`), URL remota, legado `/assets/…` em `public/` ou `../../assets/blog/…` (caso normal). */
  src: ImageMetadata | string;
  alt: string;
  width: number;
  height: number;
  class?: string;
  sizes: string;
  quality?: number;
  priority?: boolean;
  decoding?: "async" | "auto" | "sync";
  loading?: "eager" | "lazy" | "auto" | null;
  fetchpriority?: "high" | "low" | "auto" | null;
}

const props = Astro.props as Props;
const usePlainImg = isHeroRemoteUrl(props.src) || isHeroPublicAssetPath(props.src);
---

{
  usePlainImg ? (
    <img
      src={props.src}
      alt={props.alt}
      width={props.width}
      height={props.height}
      class={props.class}
      loading={props.loading ?? (props.priority ? "eager" : "lazy")}
      fetchpriority={props.fetchpriority ?? (props.priority ? "high" : "low")}
      decoding={props.decoding ?? "async"}
    />
  ) : (
    <BlogImage {...props} src={props.src as ImageMetadata} />
  )
}
