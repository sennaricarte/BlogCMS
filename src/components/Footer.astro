---
import siteConfig from "../data/site-config.json";
import type { SiteConfig } from "../lib/publisher";

const { isPt = true } = Astro.props as { isPt?: boolean };
const config = siteConfig as SiteConfig;
const footerLinks = config.footerLinks?.length ? config.footerLinks : [];
const socialLinks = config.socialLinks?.length ? config.socialLinks : [];
const year = new Date().getFullYear();
const footerTextDefault = `© ${year} ${config.nomeMarca}. Todos os direitos reservados.`;
const footerText = (config.footerText && config.footerText.trim()) || footerTextDefault;
function isExternal(href: string): boolean {
  return /^https?:\/\//i.test(href.trim());
}
---

<footer class="mt-auto border-t border-slate-200 bg-slate-50" role="contentinfo">
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    {
      footerLinks.length > 0 && (
        <nav aria-label="Rodapé do site" class="mb-4">
          <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 sm:justify-start">
            {footerLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm font-medium text-slate-600 underline-offset-4 transition hover:text-[var(--client-color-primary)] hover:underline"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
    {
      socialLinks.length > 0 && (
        <nav
          aria-label={isPt ? "Redes sociais" : "Social media"}
          class:list={[footerLinks.length > 0 ? "mb-4 border-t border-slate-200/80 pt-4" : "mb-4"]}
        >
          <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 sm:justify-start">
            {socialLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm font-medium text-slate-600 underline-offset-4 transition hover:text-[var(--client-color-primary)] hover:underline"
                  rel={isExternal(item.href) ? "me noopener noreferrer" : undefined}
                  target={isExternal(item.href) ? "_blank" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
    <p class="text-center text-sm text-slate-500 sm:text-left">{footerText}</p>
  </div>
</footer>
