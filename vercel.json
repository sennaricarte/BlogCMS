{
  "framework": "astro",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/blog/:slug",
      "destination": "/:slug",
      "permanent": true
    },
    {
      "source": "/blog/:slug/",
      "destination": "/:slug/",
      "permanent": true
    }
  ]
}
